# Backend Environment Variables
# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/taskmanager?retryWrites=true&w=majority

# JWT secret (use a strong random string — at least 32 chars)
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production

# Port (Render sets this automatically in production)
PORT=5000

# Your Render backend URL (for keep-alive cron)
RENDER_URL=https://your-app-name.onrender.com

# Frontend URL (for CORS)
CLIENT_URL=https://your-app-name.vercel.app

# Node environment
NODE_ENV=development
